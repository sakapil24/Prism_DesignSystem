{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@tokens/*":     ["./src/design-system/tokens/*"],
      "@primitives/*": ["./src/design-system/primitives/*"],
      "@components/*": ["./src/design-system/components/*"],
      "@layouts/*":    ["./src/design-system/layouts/*"],
      "@patterns/*":   ["./src/design-system/patterns/*"],
      "@icons/*":      ["./src/design-system/icons/*"],
      "@utils/*":      ["./src/design-system/utils/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
